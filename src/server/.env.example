EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
WEATHER_API_KEY=
PORT=8080
ALLOWED_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
NODE_ENV=development

# ── Nuove API (aggiungi le tue chiavi) ────────────────────────────────────────
# ExchangeRate API — free tier 1500 req/mese — https://www.exchangerate-api.com
EXCHANGE_RATE_KEY=

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini Flash API (mantenuta come riferimento)
GEMINI_API_KEY=

# Groq API (GRATIS: 14.400 req/giorno, LLaMA 3.3 70B) — https://console.groq.com/keys
# Login con Google su console.groq.com → Create API Key → incolla qui
GROQ_API_KEY=

# RapidAPI Sky Scrapper (dati Skyscanner, free tier: 500 req/mese) — https://rapidapi.com/DataCrawler/api/sky-scrapper
# Registrati su RapidAPI, abbonati al piano Free di Sky Scrapper e copia la tua X-RapidAPI-Key
RAPIDAPI_KEY=

# Kiwi.com Tequila API (alternativa a Amadeus) — https://tequila.kiwi.com
# Registrazione gratuita, no OAuth2, semplice API key
KIWI_API_KEY=

# Amadeus for Developers (opzionale) — https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Google Maps Platform — Map Tiles API + Maps JavaScript API
GOOGLE_MAPS_KEY=

# Admin — chiave per endpoint /admin/send-newsletter
ADMIN_SECRET=
