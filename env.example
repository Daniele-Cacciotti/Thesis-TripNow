# ─────────────────────────────────────────────────────────────
#  TripNow — Environment variables
#  Copy this file to ".env" and fill in your own values.
#  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development

# CORS — comma-separated list of allowed origins (optional)
ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:5500

# Weather (OpenWeatherMap) — https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key

# AI itinerary generator (Groq) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_key

# Flights — Amadeus (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Flights — optional alternative providers
KIWI_API_KEY=your_kiwi_key
RAPIDAPI_KEY=your_rapidapi_key

# Currency conversion (ExchangeRate API) — optional
EXCHANGE_RATE_KEY=your_exchangerate_key

# Email (nodemailer) — used for newsletter / contact
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_password

# Admin endpoint protection (newsletter sending)
ADMIN_SECRET=choose_a_long_random_secret

# ─────────────────────────────────────────────────────────────
#  Note: the Google Maps JavaScript API key is a CLIENT-side key
#  and lives in /src/js/config.js (not here). Restrict it by
#  HTTP referrer in the Google Cloud Console before deploying.
# ─────────────────────────────────────────────────────────────
